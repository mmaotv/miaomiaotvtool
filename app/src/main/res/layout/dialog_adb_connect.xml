<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="400dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup_menu_bg"
    android:padding="16dp">

    <!-- 标题区域 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/popup_header_bg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔗"
            android:textSize="24sp"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ADB 连接"
            android:textSize="16sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp"/>

    <!-- 说明文字 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="连接到本机无线调试端口："
        android:textSize="14sp"
        android:textColor="#5D6D7E"
        android:layout_marginBottom="8dp"/>
    
    <!-- 版本兼容提示 -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#95A5A6"
        android:visibility="gone"
        android:layout_marginBottom="8dp"/>

    <!-- 两列输入框 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- IP 输入框 - 默认 localhost -->
        <EditText
            android:id="@+id/dialogInput1"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="2"
            android:hint="127.0.0.1"
            android:text="127.0.0.1"
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:textColorHint="#BDC3C7"
            android:background="@drawable/dialog_standard_edit_bg"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:inputType="number|text"
            android:layout_marginEnd="8dp"/>

        <!-- 端口输入框 -->
        <EditText
            android:id="@+id/dialogInput2"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="端口"
            android:text="5555"
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:textColorHint="#BDC3C7"
            android:background="@drawable/dialog_standard_edit_bg"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:inputType="number"
            android:gravity="center"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp"/>

    <!-- 两列按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btnNegative"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_popup_item_bg"
            android:layout_marginEnd="6dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="取消"
                android:textSize="14sp"
                android:textColor="#7F8C8D"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnPositive"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_popup_item_bg"
            android:layout_marginStart="6dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="连接"
                android:textSize="14sp"
                android:textColor="#3498DB"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
