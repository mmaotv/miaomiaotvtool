<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_standard_bg">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ℹ️ APK 信息"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:maxHeight="400dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 应用名称 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="应用名称"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingTop="8dp"/>
            <TextView
                android:id="@+id/tvApkAppName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#FFFFFF"/>

            <!-- 包名 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="包名"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingTop="12dp"/>
            <TextView
                android:id="@+id/tvApkPackage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#00BCD4"/>

            <!-- 版本 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="版本"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingTop="12dp"/>
            <TextView
                android:id="@+id/tvApkVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#4CAF50"/>

            <!-- SDK 版本 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SDK 要求"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingTop="12dp"/>
            <TextView
                android:id="@+id/tvApkSdk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#FF9800"/>

            <!-- 文件大小 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="文件大小"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingTop="12dp"/>
            <TextView
                android:id="@+id/tvApkFileSize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#FFFFFF"/>

            <!-- 签名 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="签名信息"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingTop="12dp"/>
            <TextView
                android:id="@+id/tvApkSignature"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#9E9E9E"
                android:fontFamily="monospace"/>

            <!-- 权限 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="权限列表"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingTop="12dp"/>
            <TextView
                android:id="@+id/tvApkPermissions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#E0E0E0"
                android:lineSpacingExtra="2dp"/>

            <!-- 文件路径 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="文件路径"
                android:textSize="12sp"
                android:textColor="#888888"
                android:paddingTop="12dp"/>
            <TextView
                android:id="@+id/tvApkFilePath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#757575"
                android:fontFamily="monospace"/>

        </LinearLayout>
    </ScrollView>

    <!-- 关闭按钮 -->
    <LinearLayout
        android:id="@+id/btnCloseApkInfo"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/btn_dialog_confirm_bg"
        android:layout_marginTop="16dp"
        android:focusable="true"
        android:clickable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="关闭"
            android:textSize="16sp"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>
