<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="420dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="24dp"
    android:gravity="center">

    <!-- 标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="扫码输入/上传文件"
        android:textSize="20sp"
        android:textColor="#2C3E50"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>

    <!-- 说明 -->
    <TextView
        android:id="@+id/tvQrHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="用手机扫码二维码输入网址或上传文件"
        android:textSize="13sp"
        android:textColor="#7F8C8D"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- 二维码图片 -->
    <ImageView
        android:id="@+id/ivQrCode"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:scaleType="fitCenter"
        android:background="#FFFFFF"
        android:padding="10dp"
        android:layout_marginBottom="16dp"/>

    <!-- IP地址/端口显示（可点击） -->
    <TextView
        android:id="@+id/tvIpAddress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="正在获取IP地址..."
        android:textSize="15sp"
        android:textColor="#4ECDC4"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="8dp"
        android:background="@drawable/url_bar_bg"
        android:layout_marginBottom="6dp"/>

    <!-- 等待状态 -->
    <TextView
        android:id="@+id/tvWaitStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="等待手机打开二维码..."
        android:textSize="14sp"
        android:textColor="#FF9F1C"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- 按钮行 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- 取消按钮 -->
        <LinearLayout
            android:id="@+id/btnCancelQr"
            android:layout_width="120dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:background="@drawable/btn_tool_bg"
            android:focusable="true"
            android:clickable="true"
            android:layout_marginEnd="16dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="取消"
                android:textSize="15sp"
                android:textColor="#2C3E50"/>
        </LinearLayout>

        <!-- 已上传文件目录按钮 -->
        <LinearLayout
            android:id="@+id/btnUploadFile"
            android:layout_width="180dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:background="@drawable/btn_tools_bg_inset"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁 查看上传文件"
                android:textSize="13sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
