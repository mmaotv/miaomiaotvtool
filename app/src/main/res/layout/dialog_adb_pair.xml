<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="400dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/popup_menu_bg"
    android:padding="16dp">

    <!-- 标题区域 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp"
        android:paddingBottom="12dp"
        android:background="@drawable/popup_header_bg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔑"
            android:textSize="24sp"
            android:layout_marginEnd="12dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="无线配对"
                android:textSize="16sp"
                android:textColor="#2C3E50"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Android 11+"
                android:textSize="11sp"
                android:textColor="#95A5A6"/>
        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp"/>

    <!-- 说明文字 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="输入本机显示的配对信息："
        android:textSize="14sp"
        android:textColor="#5D6D7E"
        android:layout_marginBottom="12dp"/>

    <!-- IP 输入框 - 默认 localhost -->
    <EditText
        android:id="@+id/etHost"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:hint="127.0.0.1"
        android:text="127.0.0.1"
        android:textSize="14sp"
        android:textColor="#2C3E50"
        android:textColorHint="#BDC3C7"
        android:background="@drawable/dialog_standard_edit_bg"
        android:paddingHorizontal="14dp"
        android:singleLine="true"
        android:inputType="number|text"
        android:layout_marginBottom="8dp"/>

    <!-- 端口 + 配对码 两列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <EditText
            android:id="@+id/etPort"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="端口"
            android:text="5555"
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:textColorHint="#BDC3C7"
            android:background="@drawable/dialog_standard_edit_bg"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:inputType="number"
            android:layout_marginEnd="8dp"/>

        <EditText
            android:id="@+id/etCode"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:hint="配对码"
            android:textSize="14sp"
            android:textColor="#2C3E50"
            android:textColorHint="#BDC3C7"
            android:background="@drawable/dialog_standard_edit_bg"
            android:paddingHorizontal="14dp"
            android:singleLine="true"
            android:inputType="number"
            android:gravity="center"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp"/>

    <!-- 两列按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:id="@+id/btnNegative"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_popup_item_bg"
            android:layout_marginEnd="6dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="取消"
                android:textSize="14sp"
                android:textColor="#7F8C8D"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnPositive"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_popup_item_bg"
            android:layout_marginStart="6dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="配对"
                android:textSize="14sp"
                android:textColor="#3498DB"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
