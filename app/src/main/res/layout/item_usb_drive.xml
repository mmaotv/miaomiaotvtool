<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/item_focus_glow"
    android:padding="16dp"
    android:layout_marginBottom="8dp"
    android:focusable="true"
    android:clickable="true">

    <!-- U盘图标 -->
    <TextView
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:text="💿"
        android:textSize="32sp"
        android:gravity="center"/>

    <!-- U盘信息 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <!-- 设备名 -->
        <TextView
            android:id="@+id/tvUsbName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UDisk01"
            android:textSize="16sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"/>

        <!-- 总容量/可用容量 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">
            <TextView
                android:id="@+id/tvUsbTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="总空间: 32 GB"
                android:textSize="12sp"
                android:textColor="#7F8C8D"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" | "
                android:textSize="12sp"
                android:textColor="#7F8C8D"/>
            <TextView
                android:id="@+id/tvUsbFree"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="可用: 16 GB"
                android:textSize="12sp"
                android:textColor="#27AE60"/>
        </LinearLayout>

        <!-- 挂载路径 -->
        <TextView
            android:id="@+id/tvUsbPath"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="/storage/usb1"
            android:textSize="11sp"
            android:textColor="#BDC3C7"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- 箭头提示 -->
    <TextView
        android:id="@+id/btnOpenUsb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="▶"
        android:textSize="14sp"
        android:textColor="#00D9FF"/>

</LinearLayout>
