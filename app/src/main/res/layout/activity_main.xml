<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- ==================== 首页面板 ==================== -->
    <LinearLayout
        android:id="@+id/homePage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible"
        android:background="@drawable/home_bg"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Logo 区域 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐱"
                android:textSize="32sp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_title"
                android:textSize="32sp"
                android:textColor="#2C3E50"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>
        </LinearLayout>

        <!-- 副标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitle_text"
            android:textSize="12sp"
            android:textColor="#7F8C8D"
            android:letterSpacing="0.12"
            android:layout_marginBottom="28dp"/>

        <!-- ====== 4列2行按钮网格 ====== -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clipChildren="false"
            android:clipToPadding="false">

            <!-- 第一行：直播 | 点播 | 工具 | 历史记录 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- 直播按钮 -->
                <LinearLayout
                    android:id="@+id/btnLive"
                    android:layout_width="145dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_live_bg_inset"
                    android:layout_marginEnd="12dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"
                    android:elevation="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvBtnLive"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="直播"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- 点播按钮 -->
                <LinearLayout
                    android:id="@+id/btnVod"
                    android:layout_width="145dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_vod_bg_inset"
                    android:layout_marginEnd="12dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"
                    android:elevation="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎬"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvBtnVod"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点播"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- 工具按钮 -->
                <LinearLayout
                    android:id="@+id/btnTools"
                    android:layout_width="145dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_tools_bg_inset"
                    android:layout_marginEnd="12dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"
                    android:elevation="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔧"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvBtnTools"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="工具"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- 历史记录按钮 -->
                <LinearLayout
                    android:id="@+id/btnHistoryHome"
                    android:layout_width="145dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_qr_bg_inset"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"
                    android:elevation="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📜"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvBtnHistoryHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="历史记录"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 第二行：扫码输入 | 文件管理 | U盘 | 关于 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:clipChildren="false"
                android:clipToPadding="false">

                <!-- 扫码输入按钮 -->
                <LinearLayout
                    android:id="@+id/btnQrInput"
                    android:layout_width="145dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_file_bg_inset"
                    android:layout_marginEnd="12dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"
                    android:elevation="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvBtnQr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="扫码输入"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- 文件管理按钮 -->
                <LinearLayout
                    android:id="@+id/btnFileMgr"
                    android:layout_width="145dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_tools_bg_inset"
                    android:layout_marginEnd="12dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"
                    android:elevation="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📁"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvBtnFile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="文件管理"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- U盘按钮 -->
                <LinearLayout
                    android:id="@+id/btnUsbMgr"
                    android:layout_width="145dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_usb_bg_inset"
                    android:layout_marginEnd="12dp"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"
                    android:elevation="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💾"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:id="@+id/tvBtnUsb"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="U盘"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- 关于按钮 -->
                <LinearLayout
                    android:id="@+id/btnAbout"
                    android:layout_width="145dp"
                    android:layout_height="100dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_qr_bg_inset"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:clickable="true"
                    android:elevation="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ℹ️"
                        android:textSize="28sp"
                        android:layout_marginBottom="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="关于"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 底部提示 -->
        <TextView
            android:id="@+id/infoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/info_text"
            android:textSize="14sp"
            android:textColor="#E65100"
            android:paddingHorizontal="24dp"
            android:paddingVertical="8dp"
            android:background="@drawable/info_text_bg"
            android:layout_marginTop="24dp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- ==================== WebView页面 ==================== -->
    <LinearLayout
        android:id="@+id/webPage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#F8F9FA">

        <!-- 顶部工具栏 -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/toolbar_bg"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:elevation="4dp">

            <!-- 后退 -->
            <LinearLayout
                android:id="@+id/btnBack"
                android:layout_width="54dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_tool_bg_inset"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="◀"
                    android:textSize="15sp"
                    android:textColor="#2C3E50"/>
            </LinearLayout>

            <!-- 前进 -->
            <LinearLayout
                android:id="@+id/btnForward"
                android:layout_width="54dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_tool_bg_inset"
                android:layout_marginStart="5dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▶"
                    android:textSize="15sp"
                    android:textColor="#2C3E50"/>
            </LinearLayout>

            <!-- 刷新 -->
            <LinearLayout
                android:id="@+id/btnRefresh"
                android:layout_width="54dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_tool_bg_inset"
                android:layout_marginStart="5dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↻"
                    android:textSize="18sp"
                    android:textColor="#2C3E50"/>
            </LinearLayout>

            <!-- 可编辑地址栏 -->
            <EditText
                android:id="@+id/etUrl"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="7dp"
                android:background="@drawable/url_bar_bg"
                android:textColor="#2C3E50"
                android:textSize="13sp"
                android:paddingHorizontal="14dp"
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:textColorHint="#95A5A6"
                android:hint="输入网址..."
                android:selectAllOnFocus="true"/>

            <!-- GO按钮 -->
            <LinearLayout
                android:id="@+id/btnGo"
                android:layout_width="46dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_go_bg_inset"
                android:layout_marginEnd="5dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GO"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- 首页按钮 -->
            <LinearLayout
                android:id="@+id/btnHome"
                android:layout_width="66dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_home_bg_inset"
                android:layout_marginEnd="5dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠 首页"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- 下载管理 -->
            <LinearLayout
                android:id="@+id/btnDownloads"
                android:layout_width="70dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_download_bg_inset"
                android:layout_marginEnd="5dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📥 下载"
                    android:textSize="11sp"
                    android:textColor="#2C3E50"/>
            </LinearLayout>

            <!-- 收藏夹 -->
            <LinearLayout
                android:id="@+id/btnBookmark"
                android:layout_width="60dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_bookmark_bg_inset"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐"
                    android:textSize="18sp"
                    android:textColor="#FFB300"/>
            </LinearLayout>

            <!-- 历史记录 -->
            <LinearLayout
                android:id="@+id/btnHistory"
                android:layout_width="60dp"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_bookmark_bg_inset"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📜"
                    android:textSize="18sp"
                    android:textColor="#00D9FF"/>
            </LinearLayout>

            <!-- 投屏 -->
            <LinearLayout
                android:id="@+id/btnCast"
                android:layout_width="60dp"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_bookmark_bg_inset"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📺"
                    android:textSize="18sp"
                    android:textColor="#00D9FF"/>
            </LinearLayout>

        </LinearLayout>

        <!-- 加载进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="#00D9FF"
            android:max="100"
            android:visibility="gone"/>

        <!-- WebView -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

    </LinearLayout>

    <!-- 光标层（覆盖在最上方） -->
    <com.miaomiao.tv.CursorView
        android:id="@+id/cursorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:clickable="false"/>

</FrameLayout>
