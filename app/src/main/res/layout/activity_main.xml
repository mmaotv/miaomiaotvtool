<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <!-- ==================== 首页面板 ==================== -->
    <LinearLayout
        android:id="@+id/homePage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible"
        android:background="@drawable/home_bg">

        <!-- Logo 区域 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#128049;"
                android:textSize="36sp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_title"
                android:textSize="34sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:shadowColor="#FF6EC7"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="20"/>
        </LinearLayout>

        <!-- 副标题 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/subtitle_text"
            android:textSize="13sp"
            android:textColor="#99AABBDD"
            android:letterSpacing="0.1"
            android:layout_marginBottom="36dp"/>

        <!-- 第一行按钮：直播 + 点播 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <!-- 直播按钮 -->
            <LinearLayout
                android:id="@+id/btnLive"
                android:layout_width="190dp"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/btn_live_bg"
                android:layout_marginEnd="24dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:elevation="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128225;"
                    android:textSize="30sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#30452;  &#25773;"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"/>

            </LinearLayout>

            <!-- 点播按钮 -->
            <LinearLayout
                android:id="@+id/btnVod"
                android:layout_width="190dp"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/btn_vod_bg"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:elevation="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#127916;"
                    android:textSize="30sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#28857;  &#25773;"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"/>

            </LinearLayout>

        </LinearLayout>

        <!-- 第二行按钮：工具 + 扫码输入 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- 工具按钮 -->
            <LinearLayout
                android:id="@+id/btnTools"
                android:layout_width="190dp"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/btn_tools_bg"
                android:layout_marginEnd="24dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:elevation="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128295;"
                    android:textSize="30sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#24037;  &#20855;"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"/>

            </LinearLayout>

            <!-- 扫码输入按钮 -->
            <LinearLayout
                android:id="@+id/btnQrInput"
                android:layout_width="190dp"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/btn_qr_bg"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:elevation="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128247;"
                    android:textSize="30sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#25195;&#30721;&#36755;&#20837;"
                    android:textSize="20sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

            </LinearLayout>

        </LinearLayout>

        <!-- 文本框（密码提示），在按钮下方居中 -->
        <TextView
            android:id="@+id/infoText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/info_text"
            android:textSize="15sp"
            android:textColor="#FFDD88"
            android:paddingHorizontal="28dp"
            android:paddingVertical="10dp"
            android:background="@drawable/info_text_bg"
            android:layout_marginTop="28dp"
            android:gravity="center"/>

    </LinearLayout>

    <!-- ==================== WebView页面 ==================== -->
    <LinearLayout
        android:id="@+id/webPage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#0D0D1A">

        <!-- 顶部工具栏 -->
        <LinearLayout
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:background="@drawable/toolbar_bg"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:elevation="12dp">

            <!-- 后退 -->
            <LinearLayout
                android:id="@+id/btnBack"
                android:layout_width="54dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_tool_bg"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#9664;"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- 前进 -->
            <LinearLayout
                android:id="@+id/btnForward"
                android:layout_width="54dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_tool_bg"
                android:layout_marginStart="5dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#9654;"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- 刷新 -->
            <LinearLayout
                android:id="@+id/btnRefresh"
                android:layout_width="54dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_tool_bg"
                android:layout_marginStart="5dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#8634;"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- 可编辑地址栏 -->
            <EditText
                android:id="@+id/etUrl"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="7dp"
                android:background="@drawable/url_bar_bg"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:paddingHorizontal="14dp"
                android:singleLine="true"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:textColorHint="#88AABBCC"
                android:hint="&#36755;&#20837;&#32593;&#22336;..."
                android:selectAllOnFocus="true"/>

            <!-- GO按钮 -->
            <LinearLayout
                android:id="@+id/btnGo"
                android:layout_width="46dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_go_bg"
                android:layout_marginEnd="5dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GO"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- 首页按钮 -->
            <LinearLayout
                android:id="@+id/btnHome"
                android:layout_width="66dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_home_bg"
                android:layout_marginEnd="5dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#127968; &#39318;&#39029;"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- 下载管理 -->
            <LinearLayout
                android:id="@+id/btnDownloads"
                android:layout_width="70dp"
                android:layout_height="38dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_download_bg"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#128229; &#19979;&#36733;"
                    android:textSize="11sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

        </LinearLayout>

        <!-- 加载进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="#7B61FF"
            android:max="100"
            android:visibility="gone"/>

        <!-- WebView -->
        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

    </LinearLayout>

    <!-- 光标层（覆盖在最上方） -->
    <com.miaomiao.tv.CursorView
        android:id="@+id/cursorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        android:clickable="false"/>

</FrameLayout>
