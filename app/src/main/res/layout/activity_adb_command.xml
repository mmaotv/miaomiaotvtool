<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="8dp"
        android:elevation="4dp">

        <!-- 返回按钮（长按首页） -->
        <LinearLayout
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_home_bg_inset"
            android:paddingHorizontal="12dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀"
                android:textSize="14sp"
                android:textColor="#FFFFFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" 返回"
                android:textSize="11sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- 标题 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💻 ADB 命令终端"
            android:textSize="16sp"
            android:textColor="#2C3E50"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- 右上角：状态 + 连接 + 清空 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- ADB状态条（简化显示） -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔌 未连接"
                android:textSize="11sp"
                android:textColor="#7F8C8D"
                android:layout_marginEnd="8dp"/>

            <!-- 连接按钮 -->
            <LinearLayout
                android:id="@+id/btnConnect"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_go_bg_inset"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="6dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔗"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 连接"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>

            <!-- 清空按钮 -->
            <LinearLayout
                android:id="@+id/btnClearLog"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_tool_bg_inset"
                android:paddingHorizontal="12dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🗑"
                    android:textSize="14sp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" 清空"
                    android:textSize="12sp"
                    android:textColor="#2C3E50"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 黑色终端区域（占70%+高度） -->
    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#1E1E1E"
        android:layout_marginHorizontal="8dp"
        android:layout_marginTop="8dp"
        android:padding="10dp"
        android:fadingEdge="vertical"
        android:scrollbars="vertical">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💻 ADB 命令终端 v1.0\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\nADB 命令终端已就绪\n请先连接设备...\n\n快捷命令: pm, am, getprop, ls 等\n"
            android:textSize="12sp"
            android:textColor="#00FF00"
            android:typeface="monospace"
            android:lineSpacingExtra="3dp"/>
    </ScrollView>

    <!-- 底部控件区域（最小化） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F5F5F5"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <!-- 快捷命令按钮：单行紧凑横向滚动 -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnQuickPm"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="pm list"
                    android:textSize="11sp"
                    android:textColor="#2C3E50"
                    android:background="@drawable/btn_toolbar_bg"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/btnQuickProp"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="getprop"
                    android:textSize="11sp"
                    android:textColor="#2C3E50"
                    android:background="@drawable/btn_toolbar_bg"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/btnQuickShell"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="shell ls"
                    android:textSize="11sp"
                    android:textColor="#2C3E50"
                    android:background="@drawable/btn_toolbar_bg"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/btnQuickInstall"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="pm install"
                    android:textSize="11sp"
                    android:textColor="#2C3E50"
                    android:background="@drawable/btn_toolbar_bg"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:focusable="true"
                    android:clickable="true"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:id="@+id/btnQuickDumpsys"
                    android:layout_width="wrap_content"
                    android:layout_height="28dp"
                    android:text="dumpsys"
                    android:textSize="11sp"
                    android:textColor="#2C3E50"
                    android:background="@drawable/btn_toolbar_bg"
                    android:gravity="center"
                    android:paddingHorizontal="10dp"
                    android:focusable="true"
                    android:clickable="true"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- 命令输入框（紧凑） -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$ "
                android:textSize="14sp"
                android:textColor="#27AE60"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etCommand"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="输入 ADB 命令..."
                android:textSize="12sp"
                android:textColor="#2C3E50"
                android:textColorHint="#BDC3C7"
                android:imeOptions="actionSend"
                android:singleLine="true"
                android:paddingHorizontal="8dp"/>

            <LinearLayout
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/btn_go_bg_inset"
                android:paddingHorizontal="14dp"
                android:focusable="true"
                android:clickable="true">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="发送"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"/>
            </LinearLayout>
        </LinearLayout>

        <!-- 历史命令提示 -->
        <TextView
            android:id="@+id/tvHistoryHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="⏱ 按上下键查看历史命令"
            android:textSize="9sp"
            android:textColor="#95A5A6"
            android:visibility="gone"/>
    </LinearLayout>

</LinearLayout>