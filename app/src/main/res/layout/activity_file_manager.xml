<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- 顶部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingHorizontal="12dp"
        android:elevation="4dp">

        <!-- 返回首页 -->
        <LinearLayout
            android:id="@+id/btnBackHome"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_home_bg_inset"
            android:paddingHorizontal="14dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏠"
                android:textSize="15sp"
                android:textColor="#FFFFFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  首页"
                android:textSize="12sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- 返回上级 -->
        <LinearLayout
            android:id="@+id/btnParentDir"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_tool_bg_inset"
            android:paddingHorizontal="14dp"
            android:layout_marginStart="8dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁"
                android:textSize="15sp"
                android:textColor="#2C3E50"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  返回上级"
                android:textSize="12sp"
                android:textColor="#2C3E50"/>
        </LinearLayout>

        <!-- 当前路径 -->
        <TextView
            android:id="@+id/tvCurrentPath"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="12dp"
            android:text="/"
            android:textSize="12sp"
            android:textColor="#7F8C8D"
            android:singleLine="true"
            android:ellipsize="middle"
            android:gravity="center_vertical"/>

        <!-- 刷新 -->
        <LinearLayout
            android:id="@+id/btnRefresh"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_tool_bg_inset"
            android:paddingHorizontal="14dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↻"
                android:textSize="15sp"
                android:textColor="#2C3E50"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  刷新"
                android:textSize="12sp"
                android:textColor="#2C3E50"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 操作提示 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#ECF0F1"
        android:paddingHorizontal="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="遥控器：方向键选择  |  OK键打开/进入  |  菜单键弹出操作菜单  |  返回上级"
            android:textSize="11sp"
            android:textColor="#7F8C8D"/>
    </LinearLayout>

    <!-- 文件列表 -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">
        <LinearLayout
            android:id="@+id/fileListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"/>
    </ScrollView>

    <!-- 底部操作栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#FFFFFF"
        android:paddingHorizontal="12dp"
        android:elevation="4dp">

        <!-- 新建文件夹 -->
        <LinearLayout
            android:id="@+id/btnNewFolder"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_file_bg_inset"
            android:paddingHorizontal="18dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📁+"
                android:textSize="15sp"
                android:textColor="#FFFFFF"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  新建文件夹"
                android:textSize="13sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- 提示：菜单键操作 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_tool_bg_inset"
            android:paddingHorizontal="18dp"
            android:layout_marginStart="16dp"
            android:focusable="false"
            android:clickable="false">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☰"
                android:textSize="14sp"
                android:textColor="#2C3E50"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  菜单键：重命名/删除/移动/复制"
                android:textSize="12sp"
                android:textColor="#7F8C8D"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
