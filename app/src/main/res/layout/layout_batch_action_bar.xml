<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/batchActionBar"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="16dp"
    android:background="#E6333333"
    android:visibility="gone">

    <!-- 退出批量模式 -->
    <LinearLayout
        android:id="@+id/btnExitBatchMode"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:background="@drawable/btn_toolbar_bg"
        android:focusable="true"
        android:clickable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕ 退出"
            android:textSize="14sp"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- 计数 -->
    <TextView
        android:id="@+id/tvBatchCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="已选 0 个文件"
        android:textSize="14sp"
        android:textColor="#00D9FF"
        android:gravity="center"
        android:paddingHorizontal="8dp"/>

    <!-- 批量删除 -->
    <LinearLayout
        android:id="@+id/btnBatchDelete"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:background="@drawable/btn_toolbar_bg"
        android:focusable="true"
        android:clickable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑 删除"
            android:textSize="14sp"
            android:textColor="#FF5252"/>
    </LinearLayout>

    <!-- 批量复制 -->
    <LinearLayout
        android:id="@+id/btnBatchCopy"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:background="@drawable/btn_toolbar_bg"
        android:layout_marginStart="8dp"
        android:focusable="true"
        android:clickable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 复制"
            android:textSize="14sp"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- 批量移动 -->
    <LinearLayout
        android:id="@+id/btnBatchMove"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:background="@drawable/btn_toolbar_bg"
        android:layout_marginStart="8dp"
        android:focusable="true"
        android:clickable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✂ 移动"
            android:textSize="14sp"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

    <!-- 批量重命名 -->
    <LinearLayout
        android:id="@+id/btnBatchRename"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:background="@drawable/btn_toolbar_bg"
        android:layout_marginStart="8dp"
        android:focusable="true"
        android:clickable="true">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✏️ 重命名"
            android:textSize="14sp"
            android:textColor="#FFEB3B"/>
    </LinearLayout>

</LinearLayout>
