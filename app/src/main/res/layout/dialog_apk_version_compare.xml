<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_standard_bg">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📱 APK 版本对比"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <!-- 应用名称 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="应用名称"
        android:textSize="12sp"
        android:textColor="#888888"/>
    <TextView
        android:id="@+id/tvCompareAppName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>

    <!-- 包名 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="包名"
        android:textSize="12sp"
        android:textColor="#888888"
        android:paddingTop="8dp"/>
    <TextView
        android:id="@+id/tvComparePackage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#00BCD4"/>

    <!-- 版本对比 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <!-- APK 版本 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📦 APK 文件"
                android:textSize="12sp"
                android:textColor="#888888"/>
            <TextView
                android:id="@+id/tvCompareApkVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#4CAF50"
                android:gravity="center"
                android:paddingTop="4dp"/>
        </LinearLayout>

        <!-- 分隔符 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VS"
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_gravity="center"/>

        <!-- 已安装版本 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📱 已安装"
                android:textSize="12sp"
                android:textColor="#888888"/>
            <TextView
                android:id="@+id/tvCompareInstalledVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#FF9800"
                android:gravity="center"
                android:paddingTop="4dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 对比结果 -->
    <TextView
        android:id="@+id/tvCompareResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="对比结果"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"/>

    <!-- 按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:id="@+id/btnCompareClose"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_dialog_cancel_bg"
            android:layout_marginEnd="8dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="关闭"
                android:textSize="16sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnCompareInstall"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_dialog_confirm_bg"
            android:layout_marginStart="8dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="安装"
                android:textSize="16sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
