<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_standard_bg">

    <!-- 标题 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✏️ 批量重命名"
        android:textSize="20sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <!-- 前缀 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="添加前缀"
        android:textSize="12sp"
        android:textColor="#888888"/>
    <EditText
        android:id="@+id/etRenamePrefix"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="例如: 备份_"
        android:textColorHint="#666666"
        android:textColor="#FFFFFF"
        android:background="@drawable/edit_text_bg"
        android:padding="12dp"
        android:inputType="text"/>

    <!-- 后缀 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="添加后缀（在扩展名前）"
        android:textSize="12sp"
        android:textColor="#888888"
        android:paddingTop="12dp"/>
    <EditText
        android:id="@+id/etRenameSuffix"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="例如: _old"
        android:textColorHint="#666666"
        android:textColor="#FFFFFF"
        android:background="@drawable/edit_text_bg"
        android:padding="12dp"
        android:inputType="text"/>

    <!-- 正则替换 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="正则替换"
        android:textSize="12sp"
        android:textColor="#888888"
        android:paddingTop="12dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <EditText
            android:id="@+id/etRenameRegex"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="正则表达式"
            android:textColorHint="#666666"
            android:textColor="#FFFFFF"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:inputType="text"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  →  "
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:layout_gravity="center"/>
        <EditText
            android:id="@+id/etRenameReplace"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:hint="替换为"
            android:textColorHint="#666666"
            android:textColor="#FFFFFF"
            android:background="@drawable/edit_text_bg"
            android:padding="12dp"
            android:inputType="text"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="示例: 正则 (\\d+) 替换为 第$1"
        android:textSize="10sp"
        android:textColor="#666666"
        android:paddingTop="4dp"/>

    <!-- 按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp">

        <LinearLayout
            android:id="@+id/btnCancelRename"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_dialog_cancel_bg"
            android:layout_marginEnd="8dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="取消"
                android:textSize="16sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnConfirmRename"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/btn_dialog_confirm_bg"
            android:layout_marginStart="8dp"
            android:focusable="true"
            android:clickable="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="确认"
                android:textSize="16sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
