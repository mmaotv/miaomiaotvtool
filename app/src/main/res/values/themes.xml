<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 主题：现代浅色，无标题栏，全屏，横屏 -->
    <style name="Theme.MiaoMiaoTV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">#FFFFFF</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:statusBarColor">#FFFFFF</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <!-- 主色调：清新蓝绿 -->
        <item name="colorPrimary">#00D9FF</item>
        <item name="colorPrimaryDark">#00B8D9</item>
        <item name="colorAccent">#4ECDC4</item>
        <!-- 焦点高亮 -->
        <item name="android:colorControlHighlight">#3300D9FF</item>
    </style>
</resources>
