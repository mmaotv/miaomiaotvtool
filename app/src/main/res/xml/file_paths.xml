<?xml version="1.0" encoding="utf-8"?>
<!-- FileProvider 文件路径配置 -->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 根目录（支持所有存储设备，包括U盘） -->
    <root-path
        name="root"
        path="." />
    <!-- 公共下载目录 -->
    <external-path
        name="external_downloads"
        path="Download/" />
    <!-- 外部存储根目录 -->
    <external-path
        name="external_root"
        path="." />
    <!-- 应用私有外部存储 -->
    <external-files-path
        name="external_files"
        path="." />
    <!-- 缓存目录 -->
    <cache-path
        name="cache"
        path="." />
</paths>
