<?xml version="1.0" encoding="utf-8"?>
<!-- FileProvider 文件路径配置 -->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 公共下载目录（含子目录如 喵喵嗷影视/） -->
    <external-path
        name="external_downloads"
        path="Download/" />
    <!-- 外部存储根目录（备用） -->
    <external-path
        name="external_root"
        path="." />
    <!-- 应用私有外部存储 -->
    <external-files-path
        name="external_files"
        path="." />
    <!-- 缓存目录 -->
    <cache-path
        name="cache"
        path="." />
</paths>
