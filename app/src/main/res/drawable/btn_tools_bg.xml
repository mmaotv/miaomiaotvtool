<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 焦点选中状态：白色粗边框 + 更亮 -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#6BD98C"
                android:endColor="#4ECDC4"/>
            <corners android:radius="20dp"/>
            <stroke android:width="4dp" android:color="#2C3E50"/>
        </shape>
    </item>

    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#5AC97D"
                android:endColor="#3DBDB4"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- 默认状态：薄荷绿渐变 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#4ECDC4"
                android:endColor="#44A08D"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

</selector>
