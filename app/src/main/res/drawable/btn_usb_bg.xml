<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 焦点选中状态：白色粗边框 + 更亮渐变 -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#A29BFE"
                android:endColor="#6C5CE7"
                android:angle="135"/>
            <corners android:radius="20dp"/>
            <stroke android:width="4dp" android:color="#2C3E50"/>
        </shape>
    </item>

    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#9189EE"
                android:endColor="#5B4BD6"
                android:angle="135"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- 默认状态：薰衣草紫渐变 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#A29BFE"
                android:endColor="#6C5CE7"
                android:angle="135"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

</selector>
