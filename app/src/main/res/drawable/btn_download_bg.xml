<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 焦点选中：白色边框 + 更亮 -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFD93D"
                android:endColor="#FF9F1C"
                android:angle="45"/>
            <corners android:radius="8dp"/>
            <stroke android:width="3dp" android:color="#2C3E50"/>
        </shape>
    </item>

    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#E6C235"
                android:endColor="#E68F17"
                android:angle="45"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <!-- 默认状态：阳光黄渐变 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFD93D"
                android:endColor="#FF9F1C"
                android:angle="45"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

</selector>
