<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 焦点选中：白色边框 + 更亮 -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF4EC888"
                android:endColor="#FF3EAA68"
                android:angle="45"/>
            <corners android:radius="8dp"/>
            <stroke android:width="3dp" android:color="#FFFFFFFF"/>
        </shape>
    </item>

    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#CC259659"
                android:endColor="#CC1A7A4E"
                android:angle="45"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <!-- 默认状态 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF259659"
                android:endColor="#FF1A7A4E"
                android:angle="45"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

</selector>
