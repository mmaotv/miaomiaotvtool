<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 焦点选中状态：白色粗边框 + 更亮 -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FFB347"
                android:endColor="#FFCC33"/>
            <corners android:radius="20dp"/>
            <stroke android:width="4dp" android:color="#2C3E50"/>
        </shape>
    </item>

    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#E69F3D"
                android:endColor="#E6B82E"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- 默认状态：阳光黄渐变 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#FFD93D"
                android:endColor="#FF9F1C"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

</selector>
