<?xml version="1.0" encoding="utf-8"?>
<!-- 按钮选择器：正常/焦点/按下 - 三态清晰区分 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 按下状态：深蓝色背景 -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#1565C0" />
            <stroke android:width="2dp" android:color="#0D47A1" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- 选中状态：蓝色渐变背景（与返回按钮未选中时一致） -->
    <item android:state_focused="true">
        <shape>
            <gradient android:startColor="#2196F3" android:endColor="#1976D2" android:angle="135"/>
            <corners android:radius="8dp" />
        </shape>
    </item>
    <!-- 未选中状态：白色背景，浅灰边框 -->
    <item>
        <shape>
            <solid android:color="#FFFFFF" />
            <stroke android:width="1dp" android:color="#D1D5DB" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
