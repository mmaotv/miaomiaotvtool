<?xml version="1.0" encoding="utf-8"?>
<!-- Apple TV Light 点播按钮 - 蓝紫渐变三态 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 按下状态：深紫色 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#5E5BC7"/>
            <stroke android:width="2dp" android:color="#4A48BB"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- 选中状态：蓝色渐变背景（与返回按钮未选中时一致） -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#2196F3" android:endColor="#1976D2" android:angle="135"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <!-- 未选中状态：蓝紫渐变背景 -->
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#6670F0" android:endColor="#BF5AF2" android:angle="135"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
</selector>
