<?xml version="1.0" encoding="utf-8"?>
<!-- Apple TV 统一三态按钮样式
     状态区分：
     - 未选中：白色背景 + 浅灰色边框
     - 选中（焦点）：纯蓝色背景（和返回按钮未选中时一样）
     - 按下：深蓝色背景 + 白色文字
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#1565C0"/>
            <stroke android:width="2dp" android:color="#0D47A1"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <!-- 选中（焦点）状态 - 蓝色渐变背景（与返回按钮未选中时一致） -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#2196F3" android:endColor="#1976D2" android:angle="135"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    <!-- 未选中状态 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/>
            <stroke android:width="1dp" android:color="#D1D5DB"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
