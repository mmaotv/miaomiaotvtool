<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 焦点选中：白色边框 + 更亮 -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF6B9D"
                android:endColor="#FF8E53"
                android:angle="45"/>
            <corners android:radius="8dp"/>
            <stroke android:width="3dp" android:color="#2C3E50"/>
        </shape>
    </item>

    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#E65A8A"
                android:endColor="#E67E4D"
                android:angle="45"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

    <!-- 默认状态：珊瑚粉渐变 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FF6B9D"
                android:endColor="#FF8E53"
                android:angle="45"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>

</selector>
